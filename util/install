```cpp
#include <cmath>
#include <vector>
#include <memory>
#include <omp.h>
#include <stdexcept>

namespace biodynamo {

class Agent {
public:
    virtual ~Agent() = default;
    virtual double GetDiameter() const = 0;
    virtual void SetDiameter(double d) = 0;
    virtual double GetX() const = 0;
    virtual double GetY() const = 0;
    virtual double GetZ() const = 0;
};

class SimulationEnvironment {
public:
    virtual ~SimulationEnvironment() = default;
    virtual double GetTimeStep() const = 0;
    virtual double GetCurrentTime() const = 0;
};

class ODESolver {
public:
    virtual ~ODESolver() = default;
    virtual void Solve(std::vector<double>& state, double dt) = 0;
};

class AgentInteraction {
public:
    virtual ~AgentInteraction() = default;
    virtual double ComputeForce(const Agent& a, const Agent& b) const = 0;
};

class ThreadSafeAgentContainer {
private:
    std::vector<std::unique_ptr<Agent>> agents_;
    mutable omp_lock_t lock_;

public:
    ThreadSafeAgentContainer() { omp_init_lock(&lock_); }
    ~ThreadSafeAgentContainer() { omp_destroy_lock(&lock_); }

    void AddAgent(std::unique_ptr<Agent> agent) {
        omp_set_lock(&lock_);
        agents_.push_back(std::move(agent));
        omp_unset_lock(&lock_);
    }

    size_t Size() const {
        omp_set_lock(&lock_);
        size_t s = agents_.size();
        omp_unset_lock(&lock_);
        return s;
    }

    Agent* GetAgent(size_t index) const {
        omp_set_lock(&lock_);
        Agent* a = (index < agents_.size()) ? agents_[index].get() : nullptr;
        omp_unset_lock(&lock_);
        return a;
    }
};

class SimulationEngine {
private:
    std::unique_ptr<SimulationEnvironment> env_;
    std::unique_ptr<ODESolver> solver_;
    std::unique_ptr<AgentInteraction> interaction_;
    ThreadSafeAgentContainer agents_;
    double time_ = 0.0;

public:
    SimulationEngine(std::unique_ptr<SimulationEnvironment> env,
                     std::unique_ptr<ODESolver> solver,
                     std::unique_ptr<AgentInteraction> interaction)
        : env_(std::move(env))
        , solver_(std::move(solver))
        , interaction_(std::move(interaction)) {
        if (!env_ || !solver_ || !interaction_) {
            throw std::invalid_argument("All components must be provided");
        }
    }

    void RunSimulation(size_t num_steps) {
        const double dt = env_->GetTimeStep();
        
        for (size_t step = 0; step < num_steps; ++step) {
            UpdateAgents(dt);
            time_ += dt;
        }
    }

private:
    void UpdateAgents(double dt) {
        const size_t num_agents = agents_.Size();
        if (num_agents == 0) return;

        std::vector<double> forces(num_agents, 0.0);
        
        #pragma omp parallel for schedule(dynamic, 16) if(num_agents > 100)
        for (size_t i = 0; i < num_agents; ++i) {
            Agent* agent_i = agents_.GetAgent(i);
            if (!agent_i) continue;
            
            double local_force = 0.0;
            
            for (size_t j = i + 1; j < num_agents; ++j) {
                Agent
