```cpp
#include <cmath>
#include <vector>
#include <memory>
#include <algorithm>
#include <omp.h>

namespace biodynamo {

class Agent {
public:
    virtual ~Agent() = default;
    virtual double GetMass() const = 0;
    virtual void SetMass(double mass) = 0;
    virtual const std::vector<double>& GetPosition() const = 0;
    virtual void SetPosition(const std::vector<double>& pos) = 0;
};

class ForceCalculator {
public:
    virtual ~ForceCalculator() = default;
    virtual std::vector<double> CalculateForce(const Agent& agent1, const Agent& agent2) const = 0;
};

class GravityForce : public ForceCalculator {
private:
    double gravitational_constant_;
    
public:
    explicit GravityForce(double G) : gravitational_constant_(G) {}
    
    std::vector<double> CalculateForce(const Agent& agent1, const Agent& agent2) const override {
        const auto& pos1 = agent1.GetPosition();
        const auto& pos2 = agent2.GetPosition();
        
        if (pos1.size() != pos2.size()) {
            return std::vector<double>(pos1.size(), 0.0);
        }
        
        std::vector<double> force(pos1.size(), 0.0);
        double distance_squared = 0.0;
        
        for (size_t i = 0; i < pos1.size(); ++i) {
            double diff = pos2[i] - pos1[i];
            distance_squared += diff * diff;
        }
        
        if (distance_squared < 1e-10) {
            return force;
        }
        
        double distance = std::sqrt(distance_squared);
        double force_magnitude = gravitational_constant_ * agent1.GetMass() * agent2.GetMass() / distance_squared;
        
        for (size_t i = 0; i < pos1.size(); ++i) {
            force[i] = force_magnitude * (pos2[i] - pos1[i]) / distance;
        }
        
        return force;
    }
};

class Simulation {
private:
    std::vector<std::unique_ptr<Agent>> agents_;
    std::unique_ptr<ForceCalculator> force_calculator_;
    
public:
    explicit Simulation(std::unique_ptr<ForceCalculator> calculator)
        : force_calculator_(std::move(calculator)) {}
    
    void AddAgent(std::unique_ptr<Agent> agent) {
        agents_.push_back(std::move(agent));
    }
    
    void ComputeForces(std::vector<std::vector<double>>& forces) const {
        const size_t num_agents = agents_.size();
        forces.assign(num_agents, std::vector<double>());
        
        #pragma omp parallel for schedule(dynamic)
        for (size_t i = 0; i < num_agents; ++i) {
            forces[i].resize(agents_[i]->GetPosition().size(), 0.0);
            
            for (size_t j = 0; j < num_agents; ++j) {
                if (i == j) continue;
                
                auto force = force_calculator_->CalculateForce(*agents_[i], *agents_[j]);
                
                #pragma omp critical
                {
                    for (size_t k = 0; k < force.size(); ++k) {
                        forces[i][k] += force[k];
                    }
                }
            }
        }
    }
    
    void UpdatePositions(double dt) {
        std::vector<std::vector<double>> forces;
        ComputeForces(forces);
        
        #pragma omp parallel for
        for (size_t i = 0; i < agents_.size(); ++i) {
            auto pos = agents_[i]->GetPosition();
fi
echo "BDM_INSTALL is set to: $BDM_INSTALL"

temp_dir=$(mktemp -d)
BDM_SRC="${temp_dir}/biodynamo"
mkdir "$BDM_SRC"
cd $BDM_SRC

Colorize() {
  if [ -t 1 ]; then printf "\e[%sm%s\e[m" "$1" "$2"
  else echo -n "$2"
  fi
}

FailedClone() {
  Colorize 1 "ERROR"
  echo "Failed to git clone $1"
  exit -1
}

FailedCheckout() {
  Colorize 1 "ERROR"
  echo "Failed to git checkout $1"
  exit -1
}

Checkout() {
  # In Github Actions we checkout the branch that is running the install script
  REPO_URL="${GITHUB}/${GHA_REPOSITORY}.git"
  if [ ! -z ${GITHUB_ACTIONS+x} ]; then
    git clone --branch ${GHA_BRANCH_NAME} "$REPO_URL" . || FailedClone "$REPO_URL"
  else
    git clone "$1" . || FailedClone "$1"
    git checkout "$BDM_INSTALL" || FailedCheckout "$BDM_INSTALL"
  fi
}

# Check if git is installed
if ! command -v git 1>/dev/null 2>&1; then
  Colorize 1 "ERROR"
  echo "Git is not installed, can't continue." >&2
  exit 1
fi

if [ -n "${USE_GIT_URI}" ]; then
  GITHUB="git://github.com"
else
  GITHUB="https://github.com"
fi

# Clone BioDynaMo
Checkout "${GITHUB}/BioDynaMo/biodynamo.git"

# SBML is currently not supported anywhere
# See: https://trello.com/c/vKPbh4iG
SBML="-Dsbml=OFF"

# Log the installation process and print error message upon failure
log=${BDM_SRC}/installation.log
touch log
out_msg="Something went wrong with the installation. For more details check \
  the log file: \"${log}\""
trap "echo $out_msg" ERR

# Manifest exit code of command that is piped to tee
set -o pipefail

# In Github Actions we run the notebooks in a separate step
if [ ! -z ${GITHUB_ACTIONS+x} ]; then
  BDM_NOTEBOOKS="-Dnotebooks=off"
else
  BDM_NOTEBOOKS="-Dnotebooks=on"
fi

pwd
# Run ./install.sh
BDM_CMAKE_FLAGS="-Dtest=off $BDM_NOTEBOOKS $SBML ${BDM_CMAKE_FLAGS}" ./install.sh 2>&1 | tee "$log"

set +o pipefail
